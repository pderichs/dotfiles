#!/bin/sh

# Slightly modified version of https://gist.github.com/todgru/6224848 - thanks!

session="pat42"

# Attach to session if already present
if tmux has-session -t "$session" 2>/dev/null; then
  tmux attach -t "$session"; exit 0
fi

# set up tmux
tmux start-server

# create a new tmux session, starting editor from
# a saved session in the new window
tmux new-session -d -s $session:1 -n nvim
tmux send-keys "nvim" C-m

tmux new-window -t $session:2 -n terminal

# Source local, machine-specific extensions if present.
# Lives next to the invoked script (e.g. ~/bin/starttmux.local), not in the repo.
# See starttmux.local.example for a template.
local_script="$(dirname -- "$0")/starttmux.local"
if [ -f "$local_script" ]; then
  . "$local_script"
fi

# return to main vim window
tmux select-window -t $session:1

# Finished setup, attach to the tmux session!
tmux attach-session -t $session
